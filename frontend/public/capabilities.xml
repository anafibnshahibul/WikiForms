<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xsl="http://w3.org">
    <xsl:output method="html" encoding="UTF-8"/>
    <xsl:template match="/deviceProfile">
        <html>
            <head>
                <title>System Capabilities Sheet</title>
                <style>
                    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #fafafa; padding: 50px; }
                    .box { max-width: 600px; margin: 0 auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.04); }
                    .group-title { font-size: 16px; font-weight: bold; color: #1e293b; margin-top: 20px; padding-bottom: 5px; border-bottom: 1px dashed #e2e8f0; }
                    .prop-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px; }
                    .prop-name { color: #64748b; }
                    .prop-val { color: #0f172a; font-weight: 500; }
                </style>
            </head>
            <body>
                <div class="box">
                    <h2 style="margin:0; color:#3366cc;">Technical Specifications Profile</h2>
                    <p style="font-size:12px; color:#94a3b8; margin: 5px 0 25px 0;">Specification Blueprint: <xsl:value-of select="@specification"/></p>
                    <xsl:for-each select="component">
                        <div class="group-title"><xsl:value-of select="@group"/></div>
                        <xsl:for-each select="property">
                            <div class="prop-row">
                                <span class="prop-name"><xsl:value-of select="@name"/></span>
                                <span class="prop-val"><xsl:value-of select="@value"/></span>
                            </div>
                        </xsl:for-each>
                    </xsl:for-each>
                </div>
            </body>
        </html>
    </xsl:template>
</xsl:stylesheet>

APP_NAME=WikiForms
APP_ENV=production
APP_KEY=app_key
APP_DEBUG=false
APP_URL=https://wikiforms.toolforge.org
DB_CONNECTION=mysql
DB_HOST=your_db_host_name
DB_PORT=3306
DB_DATABASE=database
DB_USERNAME=database_username
DB_PASSWORD=database_password
LOG_CHANNEL=log_channel_name
CACHE_DRIVER=file
SESSION_DRIVER=file
WIKI_CLIENT_ID=wiki_oauth_id
WIKI_CLIENT_SECRET=wiki_oauth_secret_key
WIKI_CALLBACK_URL=callback_url
OPENROUTER_API_KEY=openrouter_api
SHELL=/bin/bash

<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="/opensearch-style.xsl"?>
<OpenSearchDescription xmlns="http://a9.com" xmlns:moz="http://mozilla.org">
    <ShortName>WikiForms</ShortName>
    <Description>Search drag &amp; drop forms and components on WikiForms</Description>
    <InputEncoding>UTF-8</InputEncoding>
    <Image width="16" height="16" type="image/x-icon">https://toolforge.org</Image>
    <!-- সার্চ রেজাল্ট পেজের ইউআরএল (আপনার সাইটের সার্চ কুয়েরি অনুযায়ী 'q=' অংশটি প্রয়োজনে পরিবর্তন করুন) -->
    <Url type="text/html" template="https://toolforge.org{searchTerms}"/>
    <!-- ব্রাউজারে টাইপ করার সময় অটো-সাজেশন দেখানোর জন্য (যদি আপনার ব্যাকএন্ডে এপিআই থাকে) -->
    <Url type="application/x-suggestions+json" template="https://toolforge.org{searchTerms}"/>
    <moz:SearchForm>https://toolforge.org</moz:SearchForm>
</OpenSearchDescription>
